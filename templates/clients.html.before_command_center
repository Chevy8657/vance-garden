<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Clients</title>
<style>
body{background:#111;color:#fff;font-family:monospace;padding:30px;}
h1{letter-spacing:2px;}
a{color:#67e8f9;}
.card{
    border:1px solid #555;
    border-radius:8px;
    padding:18px;
    margin-bottom:16px;
    color:#fff;
}
.card:hover{
    border-color:#22c55e;
    background:#181818;
}
.metric{color:#22c55e;font-weight:bold;}
.card-link{text-decoration:none;}
</style>
</head>
<body>

<h1>CLIENT INTELLIGENCE</h1>
<p><a href="/dashboard">← Back to Executive Brief</a></p>

{% for r in records %}
<a class="card-link" href="/client/{{ r.brokerage_name | urlencode }}">
<div class="card">
  <h2>{{ r.brokerage_name }}</h2>

  <div>Volume: <span class="metric">${{ "{:,.0f}".format(r.transaction_volume) }}</span></div>
  <div>GCI: <span class="metric">${{ "{:,.0f}".format(r.gci) }}</span></div>
  <div>Advisors: <span class="metric">{{ r.agent_count }}</span></div>

  <br>
  <div><b>Pain Point</b></div>
  <div>{{ r.pain_point }}</div>

  <br>
  <div><b>Strategic Goal</b></div>
  <div>{{ r.business_goal }}</div>
</div>
</a>
{% endfor %}

</body>
</html>
