<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Foundry Executive Brief</title>
    <style>
        @page {
            size: letter;
            margin: 0.5in 0.5in 0.6in 0.5in;
            @bottom-right {
                content: "Page " counter(page) " of " counter(pages);
                font-family: monospace;
                font-size: 8px;
                color: #71717a;
            }
            @bottom-left {
                content: "FOUNDRY // INTEGRITY CERTIFIED";
                font-family: monospace;
                font-size: 8px;
                color: #71717a;
                font-weight: bold;
            }
        }
        
        body {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            background-color: #ffffff;
            color: #09090b;
            margin: 0;
            padding: 0;
            font-size: 11px;
            line-height: 1.45;
        }

        /* Header Architecture */
        .header-table {
            width: 100%;
            border-bottom: 2px solid #e4e4e7;
            padding-bottom: 12px;
            margin-bottom: 20px;
        }
        .header-title {
            font-size: 16px;
            font-weight: bold;
            letter-spacing: 1px;
        }
        .header-metadata {
            font-size: 10px;
            color: #52525b;
            margin-top: 6px;
            font-weight: 500;
        }
        .meta-brand {
            color: #27272a;
            font-weight: bold;
        }
        .impact-badge {
            background-color: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 6px 12px;
            text-align: right;
            border-radius: 4px;
        }
        .impact-label {
            font-size: 8px;
            text-transform: uppercase;
            font-weight: bold;
            color: #16a34a;
            letter-spacing: 0.5px;
        }
        .impact-value {
            font-size: 16px;
            font-weight: bold;
            color: #15803d;
            margin-top: 1px;
        }

        /* Content Layout Grid */
        .grid-container {
            width: 100%;
        }
        .left-col {
            width: 33%;
            vertical-align: top;
            padding-right: 15px;
        }
        .right-col {
            width: 67%;
            vertical-align: top;
        }

        .section-title {
            font-size: 10px;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 1px;
            color: #27272a;
            border-left: 3px solid #DAA520;
            padding-left: 8px;
            margin-bottom: 10px;
        }
        .card {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            padding: 12px;
            border-radius: 4px;
            margin-bottom: 15px;
        }

        /* Elevated Readiness Hero Box */
        .readiness-hero-container {
            background-color: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 4px;
            padding: 10px;
            text-align: center;
            margin-bottom: 12px;
        }
        .readiness-hero-label {
            font-size: 8px;
            font-weight: bold;
            color: #16a34a;
            letter-spacing: 1px;
            margin-bottom: 2px;
        }
        .readiness-hero-value {
            font-size: 28px;
            font-weight: bold;
            color: #15803d;
            line-height: 1;
        }

        /* Metric Alignments */
        .status-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 8px;
            border-bottom: 1px solid #e4e4e7;
            margin-bottom: 8px;
        }
        .status-badge {
            font-weight: bold;
            font-size: 9px;
            color: #16a34a;
            text-transform: uppercase;
        }
        .metric-row {
            border-top: 1px solid #f4f4f5;
            padding: 6px 0;
        }
        .metric-label {
            color: #71717a;
            font-size: 9px;
            text-transform: uppercase;
        }
        .metric-value {
            float: right;
            font-weight: bold;
            color: #18181b;
        }

        /* Actionable Executive Signals */
        .signal-block {
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px dashed #e4e4e7;
        }
        .signal-label {
            font-size: 8px;
            color: #71717a;
            text-transform: uppercase;
            font-weight: bold;
            margin-bottom: 2px;
        }
        .signal-value {
            font-weight: bold;
            color: #18181b;
            font-size: 11px;
        }
        .signal-value.opportunity {
            color: #b45309;
        }

        /* Narrative & Recommendation Architecture */
        .narrative-block {
            margin-bottom: 12px;
        }
        .narrative-label {
            font-size: 8px;
            color: #71717a;
            text-transform: uppercase;
            font-weight: bold;
            margin-bottom: 4px;
        }
        .narrative-text {
            background-color: #fbfbfb;
            border: 1px solid #f4f4f5;
            padding: 8px 10px;
            border-radius: 4px;
            color: #27272a;
            font-size: 10.5px;
            line-height: 1.4;
        }

        /* High-Conviction Named Recommendation */
        .vance-recommendation-card {
            background-color: #f8fafc;
            border: 1px solid #cbd5e1;
            border-left: 4px solid #0f172a;
            padding: 12px;
            border-radius: 4px;
            margin-top: 12px;
        }
        .vance-rec-header {
            font-size: 9px;
            font-weight: bold;
            color: #475569;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }
        .vance-rec-title {
            font-size: 12px;
            font-weight: bold;
            color: #0f172a;
            margin-bottom: 6px;
        }
        .vance-rec-body {
            color: #334155;
            font-size: 10.5px;
            line-height: 1.4;
            margin-bottom: 8px;
        }
        .vance-rec-impact {
            font-size: 9px;
            font-weight: bold;
            color: #1e293b;
            background-color: #e2e8f0;
            display: inline-block;
            padding: 2px 6px;
            border-radius: 2px;
        }
        .vance-impact-highlight {
            color: #16a34a;
        }

        /* Plan Grid */
        .plan-table {
            width: 100%;
            margin-top: 5px;
        }
        .plan-col {
            width: 33.33%;
            vertical-align: top;
            padding-right: 10px;
        }
        .plan-card {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            padding: 10px;
            border-radius: 4px;
            min-height: 120px;
        }
        .plan-header {
            font-weight: bold;
            font-size: 9px;
            text-transform: uppercase;
            margin-bottom: 6px;
        }
        .plan-header.p1 { color: #d97706; }
        .plan-header.p2 { color: #71717a; }
        .plan-header.p3 { color: #b45309; }
        
        .plan-list {
            padding-left: 12px;
            margin: 0;
        }
        .plan-list li {
            font-size: 9.5px;
            color: #52525b;
            margin-bottom: 5px;
            line-height: 1.3;
        }
    </style>
</head>
<body>

    <table class="header-table">
        <tr>
            <td>
                <div class="header-title">FOUNDRY // EXECUTIVE BRIEF</div>
                <div class="header-metadata">
                    <span class="meta-brand">{{ brokerage_name }}</span> &middot; Q2 2026 Review &middot; Generated June 2026
                </div>
            </td>
            <td style="text-align: right; width: 220px;">
                <div class="impact-badge">
                    <div class="impact-label">Expected Annual Impact</div>
                    <div class="impact-value">{{ snapshot.expected_impact }}</div>
                </div>
            </td>
        </tr>
    </table>

    <table class="grid-container">
        <tr>
            <td class="left-col">
                <div class="section-title">Executive Snapshot</div>
                <div class="card">
                    <div class="readiness-hero-container">
                        <div class="readiness-hero-label">OWNERSHIP READINESS</div>
                        <div class="readiness-hero-value">{{ snapshot.ownership_readiness }}</div>
                    </div>

                    <div class="metric-row" style="border-top: none;">
                        <span class="metric-label">Status</span>
                        <span class="metric-value" style="color: #16a34a;">{{ snapshot.status }}</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-label">Annual Volume</span>
                        <span class="metric-value">{{ snapshot.annual_volume }}</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-label">Gross GCI</span>
                        <span class="metric-value">{{ snapshot.gci }}</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-label">Active Advisors</span>
                        <span class="metric-value">{{ snapshot.advisors }}</span>
                    </div>

                    <div class="signal-block">
                        <div class="signal-label">Greatest Strength</div>
                        <div class="signal-value">{{ strengths.greatest_strength }}</div>
                    </div>
                    <div class="signal-block">
                        <div class="signal-label">Greatest Opportunity</div>
                        <div class="signal-value opportunity">{{ strengths.greatest_opportunity }}</div>
                    </div>
                </div>
            </td>

            <td class="right-col">
                <div class="section-title">Strategic Review</div>
                <div class="card">
                    <div class="narrative-block">
                        <div class="narrative-label">01 // What Happened</div>
                        <div class="narrative-text">{{ review.what_happened }}</div>
                    </div>
                    <div class="narrative-block" style="margin-top: 8px;">
                        <div class="narrative-label">02 // What It Means</div>
                        <div class="narrative-text">{{ review.what_it_means }}</div>
                    </div>

                    <div class="vance-recommendation-card">
                        <div class="vance-rec-header">VANCE RECOMMENDS</div>
                        <div class="vance-rec-title">Deploy Automated Commission Routing Engine</div>
                        <div class="vance-rec-body">{{ review.what_to_do_next }}</div>
                        <div class="vance-rec-impact">
                            Expected Annual Impact: <span class="vance-impact-highlight">{{ snapshot.expected_impact }}</span>
                        </div>
                    </div>
                </div>
            </td>
        </tr>
    </table>

    <div class="section-title" style="margin-top: 5px;">90-Day Action Plan</div>
    <table class="plan-table">
        <tr>
            <td class="plan-col">
                <div class="plan-card">
                    <div class="plan-header p1">01 // Days 0-30</div>
                    <ul class="plan-list">
                        {% for item in action_plan.days_0_30 %}<li>{{ item }}</li>{% endfor %}
                    </ul>
                </div>
            </td>
            <td class="plan-col">
                <div class="plan-card">
                    <div class="plan-header p2">02 // Days 31-60</div>
                    <ul class="plan-list">
                        {% for item in action_plan.days_31_60 %}<li>{{ item }}</li>{% endfor %}
                    </ul>
                </div>
            </td>
            <td class="plan-col" style="padding-right: 0;">
                <div class="plan-card">
                    <div class="plan-header p3">03 // Days 61-90</div>
                    <ul class="plan-list">
                        {% for item in action_plan.days_61_90 %}<li>{{ item }}</li>{% endfor %}
                    </ul>
                </div>
            </td>
        </tr>
    </table>

</body>
</html>
